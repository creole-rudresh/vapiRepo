# ===========================================
# VAPI Configuration
# ===========================================
# Your VAPI public API key (client-side)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Your VAPI Assistant ID
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# ===========================================
# Anam.ai Configuration
# ===========================================
# Anam API Key (server-side only — NEVER expose to client)
ANAM_API_KEY=

# Anam Avatar ID — this is the correct Avatar ID for the face of your "Liv" persona
NEXT_PUBLIC_ANAM_AVATAR_ID=

# Anam Voice ID (required by API but not used — VAPI handles voice)
NEXT_PUBLIC_ANAM_VOICE_ID=

# Anam LLM ID (required by API but not used — VAPI + Gemini handles LLM)
NEXT_PUBLIC_ANAM_LLM_ID=

GEMINI_API_KEY=
